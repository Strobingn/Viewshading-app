<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/terrainLabRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0C1217"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/terrainToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:minHeight="56dp"
        app:navigationIcon="@android:drawable/ic_media_previous"
        app:title="Terrain Lab"
        app:subtitle="DEM · LAS/LAZ · 2D/3D analysis" />

    <com.viewshed.app.ui.TerrainCanvasView
        android:id="@+id/terrainCanvas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:contentDescription="Interactive terrain view"
        android:minHeight="280dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerrainImport"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Import DEM / LiDAR" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerrain2d"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2D" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerrain3d"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3D" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerrainProfile"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerrainMeasure"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Measure" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerrainExport"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Export" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerrainToggleControls"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hide controls" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/terrainControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:hint="Visualization">

                    <AutoCompleteTextView
                        android:id="@+id/dropdownTerrainMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTerrainContours"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contours" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTerrainDetect"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Find features" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTerrainLighting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Light direction 315° · altitude 35° · vertical 2.0×"
                android:textAppearance="?attr/textAppearanceBodySmall" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderTerrainAzimuth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:value="315"
                    android:valueFrom="0"
                    android:valueTo="360"
                    android:stepSize="1" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderTerrainAltitude"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:value="35"
                    android:valueFrom="5"
                    android:valueTo="85"
                    android:stepSize="1" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderTerrainExaggeration"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:value="2"
                    android:valueFrom="0.5"
                    android:valueTo="10"
                    android:stepSize="0.5" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipsGroundMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipGroundClassified"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="Class 2 ground" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipGroundAutomatic"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto bare earth" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipGroundSurface"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Surface/structures" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipsLidarDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLidarDetailLow"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LiDAR 512 fast" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLidarDetailMedium"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="LiDAR 1024 balanced" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLidarDetailHigh"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LiDAR 2048 detail" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detection: threshold · neighborhood · ground smoothing"
                android:textAppearance="?attr/textAppearanceBodySmall" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderFeatureThreshold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:value="0.45"
                    android:valueFrom="0.1"
                    android:valueTo="3"
                    android:stepSize="0.05" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderTerrainNeighborhood"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:value="8"
                    android:valueFrom="2"
                    android:valueTo="32"
                    android:stepSize="1" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderGroundSmoothing"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:value="1"
                    android:valueFrom="0"
                    android:valueTo="4"
                    android:stepSize="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTerrainLabStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="3"
                android:text="Open a GeoTIFF, ASCII grid, CSV, LAS, or LAZ file."
                android:textAppearance="?attr/textAppearanceBodySmall" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
